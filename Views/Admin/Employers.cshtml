@model IEnumerable<JobPortalSystem.Models.EmployerProfile>

@{
    ViewData["Title"] = "Manage Employers";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            Manage Employers
        </h2>

        <a asp-action="Dashboard"
           class="btn btn-secondary">
            Dashboard
        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow border-0">

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="table-dark">

                    <tr>
                        <th>Company</th>
                        <th>Industry</th>
                        <th>Location</th>
                        <th>Phone</th>
                        <th>Website</th>
                        <th width="120">Action</th>
                    </tr>

                </thead>

                <tbody>

                @foreach (var employer in Model)
                {
                    <tr>

                        <td>@employer.CompanyName</td>

                        <td>@employer.Industry</td>

                        <td>@employer.Location</td>

                        <td>@employer.Phone</td>

                        <td>@employer.Website</td>

                        <td>

                            <a asp-action="DeleteEmployer"
                               asp-route-id="@employer.EmployerProfileId"
                               class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>

    </div>

</div>