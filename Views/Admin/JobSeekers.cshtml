@model IEnumerable<JobPortalSystem.Models.JobSeeker>

@{
    ViewData["Title"] = "Manage Job Seekers";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            Manage Job Seekers
        </h2>

        <a asp-action="Dashboard"
           class="btn btn-secondary">
            Dashboard
        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow border-0">

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="table-dark">

                    <tr>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Education</th>
                        <th>Experience</th>
                        <th width="120">Action</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var seeker in Model)
                    {
                        <tr>

                            <td>@seeker.FullName</td>

                            <td>@seeker.PhoneNumber</td>

                            <td>@seeker.Education</td>

                            <td>@seeker.Experience</td>

                            <td>

                                <a asp-action="DeleteJobSeeker"
                                   asp-route-id="@seeker.JobSeekerId"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>