@model IEnumerable<JobPortalSystem.Models.Job>

@{
    ViewData["Title"] = "Manage Jobs";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            Manage Jobs
        </h2>

        <a asp-action="Dashboard"
           class="btn btn-secondary">
            Dashboard
        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow border-0">

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="table-dark">

                    <tr>
                        <th>Job Title</th>
                        <th>Company</th>
                        <th>Location</th>
                        <th>Salary</th>
                        <th>Posted</th>
                        <th width="120">Action</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var job in Model)
                    {
                        <tr>

                            <td>@job.Title</td>

                            <td>@job.CompanyName</td>

                            <td>@job.Location</td>

                            <td>Rs. @job.Salary.ToString("N0")</td>

                            <td>@job.PostedDate.ToString("dd MMM yyyy")</td>

                            <td>

                                <a asp-action="DeleteJob"
                                   asp-route-id="@job.JobId"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>

                            </td>
                            <td>

                                @if (job.Status == "Approved")
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else if (job.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }

                            </td>

                            <td>

                                <a asp-action="ApproveJob"
                                   asp-route-id="@job.JobId"
                                   class="btn btn-success btn-sm">

                                    Approve

                                </a>

                                <a asp-action="RejectJob"
                                   asp-route-id="@job.JobId"
                                   class="btn btn-danger btn-sm">

                                    Reject

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>