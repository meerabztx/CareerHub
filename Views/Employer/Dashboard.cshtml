@model JobPortalSystem.ViewModels.EmployerDashboardViewModel

@{
    ViewData["Title"] = "Employer Dashboard";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                Employer Dashboard
            </h2>

            <p class="text-muted mb-0">
                Welcome back! Here's an overview of your recruitment activity.
            </p>
        </div>

        <a asp-action="CreateJob"
           class="btn btn-success">
            <i class="bi bi-plus-circle"></i>
            Post New Job
        </a>

    </div>

    <!-- Statistics -->

    <div class="row g-4 mb-5">

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <i class="bi bi-briefcase display-5 text-primary"></i>

                    <h2 class="fw-bold mt-3">
                        @Model.TotalJobs
                    </h2>

                    <p class="text-muted mb-0">
                        Total Jobs
                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <i class="bi bi-people display-5 text-success"></i>

                    <h2 class="fw-bold mt-3">
                        @Model.TotalApplications
                    </h2>

                    <p class="text-muted mb-0">
                        Applications
                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <i class="bi bi-clock-history display-5 text-warning"></i>

                    <h2 class="fw-bold mt-3">
                        @Model.PendingApplications
                    </h2>

                    <p class="text-muted mb-0">
                        Pending
                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <i class="bi bi-x-circle display-5 text-danger"></i>

                    <h2 class="fw-bold mt-3">
                        @Model.RejectedApplications
                    </h2>

                    <p class="text-muted mb-0">
                        Rejected
                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="row">

        <!-- Quick Actions -->

        <div class="col-lg-4 mb-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-primary text-white">

                    <h5 class="mb-0">
                        Quick Actions
                    </h5>

                </div>

                <div class="card-body">

                    <a asp-action="CompanyProfile"
                       class="btn btn-outline-primary w-100 mb-3">
                        <i class="bi bi-building"></i>
                        Company Profile
                    </a>

                    <a asp-action="CreateJob"
                       class="btn btn-outline-success w-100 mb-3">
                        <i class="bi bi-plus-circle"></i>
                        Post New Job
                    </a>

                    <a asp-action="MyJobs"
                       class="btn btn-outline-dark w-100">
                        <i class="bi bi-list-ul"></i>
                        Manage Jobs
                    </a>

                </div>

            </div>

        </div>

        <!-- Recent Jobs -->

        <div class="col-lg-8">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-dark text-white">

                    <h5 class="mb-0">
                        Recent Jobs
                    </h5>

                </div>

                <div class="card-body">

                    @if (!Model.RecentJobs.Any())
                    {
                        <div class="text-center py-4">

                            <i class="bi bi-briefcase display-4 text-secondary"></i>

                            <h5 class="mt-3">
                                No jobs posted yet
                            </h5>

                            <p class="text-muted">
                                Start by posting your first vacancy.
                            </p>

                        </div>
                    }
                    else
                    {
                        <table class="table table-hover align-middle">

                            <thead>

                                <tr>
                                    <th>Job</th>
                                    <th>Location</th>
                                    <th>Salary</th>
                                    <th>Posted</th>
                                </tr>

                            </thead>

                            <tbody>

                                @foreach (var job in Model.RecentJobs)
                                {
                                    <tr>

                                        <td>
                                            <strong>@job.Title</strong>
                                        </td>

                                        <td>@job.Location</td>

                                        <td>Rs. @job.Salary.ToString("N0")</td>

                                        <td>@job.PostedDate.ToString("dd MMM yyyy")</td>

                                    </tr>
                                }

                            </tbody>

                        </table>
                    }

                </div>

            </div>

        </div>

    </div>

</div>