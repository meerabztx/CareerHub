@model IEnumerable<JobPortalSystem.Models.Job>

@{
    ViewData["Title"] = "My Jobs";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">My Job Listings</h2>
            <p class="text-muted mb-0">
                Manage and monitor all jobs posted by your company.
            </p>
        </div>

        <a asp-controller="Employer"
           asp-action="CreateJob"
           class="btn btn-success">
            <i class="bi bi-plus-circle"></i>
            Post New Job
        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0">

            <div class="card-body text-center p-5">

                <i class="bi bi-briefcase display-1 text-secondary"></i>

                <h3 class="mt-3">
                    No Jobs Posted Yet
                </h3>

                <p class="text-muted">
                    Start hiring by posting your first job opening.
                </p>

                <a asp-controller="Employer"
                   asp-action="CreateJob"
                   class="btn btn-primary mt-2">
                    Post Your First Job
                </a>

            </div>

        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">

            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">

                        <tr>
                            <th>Job Title</th>
                            <th>Location</th>
                            <th>Salary</th>
                            <th>Posted</th>
                            <th class="text-center">Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var job in Model)
                        {
                            <tr>

                                <td>
                                    <strong>@job.Title</strong><br />
                                    <small class="text-muted">
                                        @job.CompanyName
                                    </small>
                                </td>

                                <td>@job.Location</td>

                                <td>
                                    Rs. @job.Salary.ToString("N0")
                                </td>

                                <td>
                                    @job.PostedDate.ToString("dd MMM yyyy")
                                </td>

                                <td class="text-center">

                                    <a asp-controller="Jobs"
                                       asp-action="Details"
                                       asp-route-id="@job.JobId"
                                       class="btn btn-sm btn-outline-info">
                                        View
                                    </a>

                                    <a asp-controller="Jobs"
                                       asp-action="Edit"
                                       asp-route-id="@job.JobId"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <a asp-controller="Jobs"
                                       asp-action="Delete"
                                       asp-route-id="@job.JobId"
                                       class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                    <a asp-action="Applicants"
                                       asp-route-id="@job.JobId"
                                       class="btn btn-sm btn-success">
                                        Applicants
                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    }

</div>