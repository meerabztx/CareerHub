@model IEnumerable<JobPortalSystem.Models.JobSeeker>

@{
    ViewData["Title"] = "Job Seeker Profiles";
}

<h1>Job Seeker Profiles</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Profile</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>User ID</th>
            <th>Full Name</th>
            <th>Phone Number</th>
            <th>Skills</th>
            <th>Experience</th>
            <th>Education</th>
            <th>Resume</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.UserId</td>
                    <td>@item.FullName</td>
                    <td>@item.PhoneNumber</td>
                    <td>@item.Skills</td>
                    <td>@item.Experience</td>
                    <td>@item.Education</td>

                    <!-- Resume Column -->
                    <td>
                        @if (!string.IsNullOrEmpty(item.ResumePath))
                        {
                            <a href="@item.ResumePath"
                               target="_blank"
                               class="btn btn-success btn-sm">
                                View Resume
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No Resume</span>
                        }
                    </td>

                    <td>
                        <a asp-action="Edit"
                           asp-route-id="@item.JobSeekerId"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@item.JobSeekerId"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.JobSeekerId"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center text-muted">
                    No job seeker profiles found.
                </td>
            </tr>
        }
    </tbody>
</table>