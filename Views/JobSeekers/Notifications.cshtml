@model IEnumerable<JobPortalSystem.Models.Notification>

@{
    ViewData["Title"] = "Notifications";

    var unreadCount = Model.Count(x => !x.IsRead);
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">
                Notifications
            </h2>

            <p class="text-muted mb-0">
                You have
                <span class="fw-bold text-primary">
                    @unreadCount
                </span>
                unread notification(s).
            </p>
        </div>

        <div>

            @if (Model.Any(x => !x.IsRead))
            {
                <a asp-action="ReadAllNotifications"
                   class="btn btn-success me-2">
                    <i class="bi bi-check2-all"></i>
                    Mark All Read
                </a>
            }

            <a asp-controller="Jobs"
               asp-action="Index"
               class="btn btn-outline-primary">
                <i class="bi bi-briefcase"></i>
                Browse Jobs
            </a>

        </div>

    </div>

    @if (!Model.Any())
    {
        <div class="card shadow border-0">

            <div class="card-body text-center py-5">

                <i class="bi bi-bell display-1 text-secondary"></i>

                <h3 class="mt-3">
                    No Notifications
                </h3>

                <p class="text-muted">
                    Employers haven't responded to your applications yet.
                </p>

            </div>

        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            var cardClass = "border-start border-4 ";

            if (item.Title.Contains("Accepted"))
            {
                cardClass += "border-success";
            }
            else if (item.Title.Contains("Rejected"))
            {
                cardClass += "border-danger";
            }
            else
            {
                cardClass += "border-primary";
            }

            <div class="card shadow-sm @cardClass mb-3 @(item.IsRead ? "opacity-75" : "")">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h5 class="fw-bold">

                                @item.Title

                                @if (!item.IsRead)
                                {
                                    <span class="badge bg-danger ms-2">
                                        New
                                    </span>
                                }

                            </h5>

                            <p class="mb-2">
                                @item.Message
                            </p>

                            <small class="text-muted">
                                @item.CreatedAt.ToString("dd MMM yyyy hh:mm tt")
                            </small>

                        </div>

                        @if (!item.IsRead)
                        {
                            <div>

                                <a asp-action="ReadNotification"
                                   asp-route-id="@item.NotificationId"
                                   class="btn btn-success btn-sm">

                                    <i class="bi bi-check-circle"></i>
                                    Mark as Read

                                </a>

                            </div>
                        }

                    </div>

                </div>

            </div>
        }
    }

</div>