@model IEnumerable<JobPortalSystem.Models.Job>

@{
    ViewData["Title"] = "Browse Jobs";
    var appliedJobs = ViewBag.AppliedJobs as List<int>;
}

<div class="container py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">Available Jobs</h2>
            <p class="text-muted mb-0">
                Find your next career opportunity.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Post Job
        </a>

    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info shadow-sm">
            No jobs have been posted yet.
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="card shadow-sm border-0 mb-4">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h3 class="fw-bold text-primary">
                                @item.Title
                            </h3>

                            <h5 class="text-secondary">
                                @item.CompanyName
                            </h5>

                        </div>

                        <span class="badge bg-primary align-self-start">
                            Rs. @item.Salary
                        </span>

                    </div>

                    <p class="text-muted mt-3">
                        @item.Description
                    </p>

                    <div class="row mt-4">

                        <div class="col-md-4 mb-3">
                            <strong>
                                <i class="bi bi-tools"></i>
                                Skills
                            </strong>
                            <br />
                            @item.RequiredSkills
                        </div>

                        <div class="col-md-3 mb-3">
                            <strong>
                                <i class="bi bi-geo-alt"></i>
                                Location
                            </strong>
                            <br />
                            @item.Location
                        </div>

                        <div class="col-md-3 mb-3">
                            <strong>
                                <i class="bi bi-calendar-event"></i>
                                Posted
                            </strong>
                            <br />
                            @item.PostedDate.ToShortDateString()
                        </div>

                    </div>

                    <hr />

                    <div class="d-flex flex-wrap gap-2">

                        <a asp-action="Details"
                           asp-route-id="@item.JobId"
                           class="btn btn-outline-primary">
                            <i class="bi bi-eye"></i>
                            Details
                        </a>

                        @if (User.IsInRole("Employer"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.JobId"
                               class="btn btn-outline-warning">
                                <i class="bi bi-pencil-square"></i>
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.JobId"
                               class="btn btn-outline-danger">
                                <i class="bi bi-trash"></i>
                                Delete
                            </a>
                        }

                        @if (User.IsInRole("JobSeeker"))
                        {
                            @if (appliedJobs != null && appliedJobs.Contains(item.JobId))
                            {
                                <button class="btn btn-success" disabled>
                                    <i class="bi bi-check-circle-fill"></i>
                                    Applied
                                </button>
                            }
                            else
                            {
                                <form asp-action="Apply" method="post" class="d-inline">
                                    <input type="hidden" name="jobId" value="@item.JobId" />

                                    <button type="submit" class="btn btn-success">
                                        <i class="bi bi-send-fill"></i>
                                        Apply Now
                                    </button>
                                </form>
                            }
                        }

                    </div>

                </div>

            </div>
        }
    }

</div>